{
  "name": "nextra-dgmo",
  "version": "0.2.3",
  "description": "Nextra integration to render DGMO diagrams from fenced code blocks at build time. Two-step install: `withDgmo()` in next.config.mjs plus `<DgmoClient />` in app/layout.tsx — the client component handles route-change rebinding and auto-imports the theme-aware stylesheet.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/diagrammo/nextra-dgmo.git"
  },
  "homepage": "https://github.com/diagrammo/nextra-dgmo#readme",
  "bugs": {
    "url": "https://github.com/diagrammo/nextra-dgmo/issues"
  },
  "keywords": [
    "nextra",
    "next",
    "nextjs",
    "dgmo",
    "diagrammo",
    "diagram",
    "diagrams",
    "mdx",
    "markdown",
    "remark"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./config": {
      "types": "./dist/config.d.ts",
      "import": "./dist/config.js",
      "default": "./dist/config.js"
    },
    "./remark": {
      "types": "./dist/remark.d.ts",
      "import": "./dist/remark.js",
      "default": "./dist/remark.js"
    },
    "./client": {
      "types": "./dist/nextra-client.d.ts",
      "import": "./dist/nextra-client.js",
      "default": "./dist/nextra-client.js"
    },
    "./client.css": "./dist/client.css"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20.6"
  },
  "scripts": {
    "build": "tsup && node scripts/build-css.mjs",
    "postbuild": "test -f dist/client.css && test -f dist/nextra-client.js",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "pretest": "pnpm build",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check:deadcode": "knip",
    "check:duplication": "jscpd ./src",
    "check:deps": "depcheck --ignores='nextra-dgmo'",
    "check:all": "pnpm check:deadcode && pnpm check:duplication && pnpm check:deps",
    "prepublishOnly": "pnpm build && pnpm test"
  },
  "peerDependencies": {
    "@diagrammo/dgmo": ">=0.45.0 <1",
    "next": "^15.0.0 || ^16.0.0",
    "nextra": "^4.0.0",
    "react": "^19.0.0"
  },
  "peerDependenciesMeta": {
    "next": {
      "optional": false
    },
    "nextra": {
      "optional": false
    },
    "react": {
      "optional": false
    }
  },
  "dependencies": {
    "remark-dgmo": "^0.5.3"
  },
  "devDependencies": {
    "@diagrammo/dgmo": "^0.48.1",
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@vitest/coverage-v8": "^4.1.6",
    "depcheck": "^1.4.7",
    "eslint": "^10.4.0",
    "jscpd": "^4.0.9",
    "knip": "^6.14.1",
    "next": "^16.0.0",
    "nextra": "^4.0.0",
    "prettier": "^3.8.3",
    "react": "^19.0.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.59.3",
    "vitest": "^4.1.4"
  }
}
